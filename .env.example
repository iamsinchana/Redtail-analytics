# ============================================
# Redtail-Analytics Environment Configuration
# ============================================

# --- Backend Configuration ---
# YOLOv8 model to use (yolov8n.pt, yolov8s.pt, yolov8m.pt)
MODEL_NAME=yolov8n.pt

# Detection confidence threshold (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.35

# IOU threshold for NMS
IOU_THRESHOLD=0.45

# Video source: "webcam", file path, or RTSP URL
# Leave empty for demo mode
VIDEO_SOURCE=

# --- Analytics Configuration ---
# Number of people in a zone to trigger crowd alert
CROWD_THRESHOLD=5

# Maximum seconds to keep events in memory
EVENT_RETENTION_SECONDS=3600

# --- Server Configuration ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- MLflow Configuration ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=redtail-analytics

# --- Frontend Configuration ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
