# Redtail-Analytics Backend Environment Variables
# Copy to .env and adjust as needed

# ── Application ──────────────────────────────────────────────────────
APP_NAME=Redtail-Analytics
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins; use * for development
CORS_ORIGINS=["*"]

# ── YOLOv8 Model ─────────────────────────────────────────────────────
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
DEVICE=cpu

# ── Video ────────────────────────────────────────────────────────────
# Set to a file path, RTSP URL, or leave empty for demo mode
# VIDEO_SOURCE=
FRAME_WIDTH=640
FRAME_HEIGHT=480
MAX_FPS=30

# ── Analytics ────────────────────────────────────────────────────────
CROWD_THRESHOLD=5
LINE_POSITION_Y_RATIO=0.5
MAX_EVENTS=500

# ── MLflow ───────────────────────────────────────────────────────────
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=redtail-analytics
MLFLOW_LOG_INTERVAL_SECONDS=30.0

# ── Demo Mode ────────────────────────────────────────────────────────
DEMO_MODE=true

# ── Upload ───────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
